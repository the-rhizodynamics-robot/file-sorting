#!/usr/bin/env python3
"""image-sort -- friendly launcher for the file-sorting Nextflow pipeline.

Runs entirely inside WSL/Linux and hides the pipeline's sharp edges:
  - preflight-checks the environment (nextflow / java / docker) up front
  - accepts a pasted Windows path (C:\\...) and converts it to /mnt/c/...
  - runs on fast ext4 (~/image-sort-runs), then optionally copies the
    results to a folder you choose (e.g. back onto your Windows desktop)
  - drives the two-phase sort -> finish(video) workflow
  - works around the "shelf count = last char of folder name" quirk (see below)

Stdlib only -- nothing to pip-install. Install with one curl line (see README).
"""
import argparse
import os
import shutil
import subprocess
import sys
from pathlib import Path

PIPELINE = "the-rhizodynamics-robot/file-sorting"
REVISION = "main"
RUNS_BASE = Path.home() / "image-sort-runs"


def win_to_wsl(p: str) -> str:
    """C:\\Users\\x -> /mnt/c/Users/x ; leave POSIX paths alone."""
    p = p.strip().strip('"').strip("'")
    if len(p) >= 2 and p[1] == ":" and p[0].isalpha():
        return f"/mnt/{p[0].lower()}/" + p[2:].replace("\\", "/").lstrip("/")
    return p.replace("\\", "/")


def to_path(raw: str, what: str) -> Path:
    """Convert a pasted Windows/WSL path to a Path, rejecting UNC paths clearly."""
    s = raw.strip().strip('"').strip("'")
    if s.startswith("\\\\") or s.startswith("//"):
        sys.exit(
            f"{what}: network/UNC paths (\\\\server\\share) aren't supported here.\n"
            "Copy the data onto a local drive (e.g. C:\\...) or into WSL first."
        )
    return Path(win_to_wsl(s))


def win_display(p: Path):
    """/mnt/c/Users/x -> C:\\Users\\x for display; None if not a Windows mount."""
    s = str(p)
    if s.startswith("/mnt/") and len(s) > 6 and s[6] == "/":
        return s[5].upper() + ":" + s[6:].replace("/", "\\")
    return None


def wsl_unc(p: Path) -> str:
    distro = os.environ.get("WSL_DISTRO_NAME", "Ubuntu")
    return "\\\\wsl.localhost\\" + distro + str(p).replace("/", "\\")


def on_wsl() -> bool:
    """True only on WSL (so we don't print Windows-isms on a native Linux box)."""
    if os.environ.get("WSL_DISTRO_NAME"):
        return True
    try:
        return "microsoft" in Path("/proc/version").read_text().lower()
    except OSError:
        return False


def preflight():
    """Fail early, with a clear message, if the environment isn't ready."""
    missing = []
    if not shutil.which("nextflow"):
        missing.append("nextflow  (https://www.nextflow.io/ -- needs Java 11+)")
    if not shutil.which("java"):
        missing.append("java 11+  (e.g. sudo apt install default-jre)")
    if not shutil.which("docker"):
        missing.append("docker    (the Docker engine)")
    if missing:
        sys.exit("Missing required tools:\n  - " + "\n  - ".join(missing))

    r = subprocess.run(["docker", "info"], stdout=subprocess.DEVNULL,
                       stderr=subprocess.PIPE, text=True)
    if r.returncode != 0:
        if "permission denied" in (r.stderr or "").lower():
            sys.exit(
                "Docker is installed but you don't have permission to use it.\n"
                "Add yourself to the docker group, then restart WSL:\n"
                "  sudo usermod -aG docker $USER\n"
                "  (then run `wsl --shutdown` from Windows and reopen Ubuntu)"
            )
        sys.exit(
            "Docker is installed but the daemon isn't reachable.\n"
            "Start it (Docker Desktop, or `sudo service docker start`) and try again."
        )


def ask(msg, default=None, cast=str, ok=lambda v: True):
    while True:
        raw = input(f"{msg}{f' [{default}]' if default is not None else ''}: ").strip()
        if not raw:
            if default is not None:
                return default
            print("  (required)")
            continue
        try:
            val = cast(raw)
        except ValueError:
            print(f"  not a valid {cast.__name__}")
            continue
        if not ok(val):
            print("  invalid value")
            continue
        return val


def ask_yes(msg, default=True):
    raw = input(f"{msg} [{'Y/n' if default else 'y/N'}]: ").strip().lower()
    return default if not raw else raw.startswith("y")


def run_step(cmd, env, cwd):
    if subprocess.run(cmd, env=env, cwd=str(cwd)).returncode != 0:
        sys.exit("\nA pipeline step failed -- see the Nextflow output above.")


def main():
    ap = argparse.ArgumentParser(description="Sort robot images and build root-growth videos.")
    ap.add_argument("--images", help="Path to the images folder (Windows or WSL path).")
    ap.add_argument("--name", help="Name for this run (a folder under ~/image-sort-runs).")
    ap.add_argument("--overwrite", action="store_true",
                    help="If a run with this name already exists, delete it and start fresh.")
    ap.add_argument("--dest", help="Copy results here when done (Windows or Linux path). "
                                   "Optional -- results always remain in the run dir too.")
    ap.add_argument("--boxes-per-shelf", type=int)
    ap.add_argument("--shelves", type=int)
    ap.add_argument("--video", dest="video", action="store_true", default=None,
                    help="Also build the stabilized video.")
    ap.add_argument("--no-video", dest="video", action="store_false")
    a = ap.parse_args()
    interactive = a.images is None
    wsl = on_wsl()

    preflight()

    img_prompt = "Images folder" + (" (paste the Windows C:\\ path)" if wsl else "")
    images = to_path(a.images if a.images else ask(img_prompt), "Images folder")
    if not images.is_dir():
        hint = ("\n(if this is on a network or external drive, it may not be mounted in WSL)"
                if str(images).startswith("/mnt/") else "")
        sys.exit(f"Images folder not found: {images}{hint}")

    boxes = a.boxes_per_shelf or ask("Boxes per shelf", default=2, cast=int, ok=lambda v: v > 0)
    shelves = a.shelves or ask("Number of shelves", default=2, cast=int, ok=lambda v: v > 0)
    make_video = a.video if a.video is not None else (ask_yes("Make stabilized video?") if interactive else False)
    name = a.name or (ask("Run name", default=images.name) if interactive else images.name)

    if a.dest is not None:
        dest_raw = a.dest
    elif interactive:
        dest_hint = "Windows path, or " if wsl else ""
        dest_raw = input(f"Copy results to ({dest_hint}Enter to keep here): ").strip()
    else:
        dest_raw = ""
    dest = to_path(dest_raw, "Destination").resolve() if dest_raw else None

    # A sort run can't ingest into an already-populated project: the pipeline does
    # shutil.copytree(images -> unsorted_unlabeled/input1), which errors if that dir
    # exists (container Python 3.7 has no dirs_exist_ok). So a same-name re-run would
    # crash cryptically -- guard it: overwrite (fresh) or refuse.
    run_dir = (RUNS_BASE / name).resolve()
    if run_dir.exists():
        if a.overwrite or (interactive and ask_yes(
                f"A run named '{name}' already exists at {run_dir}.\n"
                "  Overwrite it (delete and start fresh)?", default=False)):
            shutil.rmtree(run_dir)
        else:
            sys.exit(f"Run '{name}' already exists -- pick a different --name, or pass "
                     f"--overwrite to replace it.\n  Existing: {run_dir}")
    sort_path = run_dir / "sorting_project"
    work_dir = run_dir / "work"
    sort_path.mkdir(parents=True, exist_ok=True)

    # Shelf-count workaround: the pipeline infers shelves from the LAST CHARACTER of the
    # images folder name and computes num_boxes = boxes_per_shelf * shelves. We can't rename
    # the user's folder, so we stage a symlink whose name ends in "1" and pass the *total*
    # box count as --boxes_per_shelf. Then num_boxes = (boxes*shelves) * 1, correct for any
    # shelf count (incl. >= 10). Removed once the run-config manifest lands.
    staged = run_dir / "input1"
    if staged.is_symlink() or staged.exists():
        staged.unlink()
    staged.symlink_to(images, target_is_directory=True)
    total_boxes = boxes * shelves

    base = ["nextflow", "run", PIPELINE, "-r", REVISION, "-profile", "local",
            "-work-dir", str(work_dir),
            "--images_path", str(staged),
            "--sort_path", str(sort_path),
            "--boxes_per_shelf", str(total_boxes),
            "--unzip", "false", "--archive", "false"]
    env = dict(os.environ)

    print(f"\n-> Sorting {images.name}  ({boxes} boxes x {shelves} shelves = {total_boxes} positions)...")
    run_step(base, env, run_dir)
    if make_video:
        print("-> Rendering video...")
        run_step(base + ["--finish_only", "true"], env, run_dir)

    if dest:
        print(f"-> Copying results to {win_display(dest) or dest} ...")
        try:
            dest.mkdir(parents=True, exist_ok=True)
            shutil.copytree(sort_path, dest, dirs_exist_ok=True)
        except (PermissionError, OSError) as e:
            sys.exit(f"\nCould not write results to {dest}:\n  {e}\n"
                     f"The sorted output is still in WSL at:\n  {sort_path}")

    print("\nDone. Results:")
    print(f"  Output: {sort_path}")
    if make_video:
        print(f"  Video:  {sort_path / 'data' / 'videos' / 'stabilized'}")
    if wsl:
        print(f"  Open in Explorer: {wsl_unc(sort_path)}")
    if dest:
        print(f"  Copied to: {win_display(dest) or dest}")


if __name__ == "__main__":
    main()
