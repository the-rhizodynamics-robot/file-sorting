#!/usr/bin/env python3
"""image-sort -- friendly launcher for the file-sorting Nextflow pipeline.

One persistent location: point every run at the same output location (--out) and the
pipeline accumulates everything there. That location holds just two trees --
data/master_data (experiments) and data/videos (finished stabilized videos). Experiments
finish (move to finished_exp + stabilized video) automatically when a later run adds no
new images to them; you can also finish specific experiments, or finish everything, on
demand.

Modes:
  sort        Sort a run's images into the location (default). Videos appear on their own
              as experiments go static across runs.
  finish      Finalize specific experiment number(s) now (move to finished + video).
  finish-all  Finalize everything currently in the location (turn it over).

Imaging geometry comes from the run folder's name: the robot names runs
<timestamp>_<shelves>_<boxes> (e.g. 20260613120000_3_8), so the shelf count and
boxes-per-shelf are both read from it -- you don't enter them. Use --shelves /
--boxes-per-shelf to override for ad-hoc folders.

Transient working files (Nextflow work dir, run staging) live under ~/.cache/image-sort,
never in your output location. Stdlib only -- nothing to pip-install (see README to install).
"""
import argparse
import hashlib
import json
import os
import shutil
import subprocess
import sys
from pathlib import Path

PIPELINE = "the-rhizodynamics-robot/file-sorting"
REVISION = "main"
CACHE = Path.home() / ".cache" / "image-sort"


# ---------- path helpers ----------
def win_to_wsl(p: str) -> str:
    """C:\\Users\\x -> /mnt/c/Users/x ; leave POSIX paths alone."""
    p = p.strip().strip('"').strip("'")
    if len(p) >= 2 and p[1] == ":" and p[0].isalpha():
        return f"/mnt/{p[0].lower()}/" + p[2:].replace("\\", "/").lstrip("/")
    return p.replace("\\", "/")


def to_path(raw: str, what: str) -> Path:
    """Convert a pasted Windows/WSL path to a Path, rejecting UNC paths clearly."""
    s = raw.strip().strip('"').strip("'")
    if s.startswith("\\\\") or s.startswith("//"):
        sys.exit(
            f"{what}: network/UNC paths (\\\\server\\share) aren't supported here.\n"
            "Copy the data onto a local drive (e.g. C:\\...) or into WSL first."
        )
    return Path(win_to_wsl(s))


def win_display(p: Path):
    """/mnt/c/Users/x -> C:\\Users\\x for display; None if not a Windows mount."""
    s = str(p)
    if s.startswith("/mnt/") and len(s) > 6 and s[6] == "/":
        return s[5].upper() + ":" + s[6:].replace("/", "\\")
    return None


def wsl_unc(p: Path) -> str:
    distro = os.environ.get("WSL_DISTRO_NAME", "Ubuntu")
    return "\\\\wsl.localhost\\" + distro + str(p).replace("/", "\\")


def on_wsl() -> bool:
    """True only on WSL (so we don't print Windows-isms on a native Linux box)."""
    if os.environ.get("WSL_DISTRO_NAME") or os.environ.get("WSL_INTEROP"):
        return True
    if shutil.which("wslpath") or Path("/run/WSL").is_dir():
        return True
    try:
        return "microsoft" in Path("/proc/sys/kernel/osrelease").read_text().lower()
    except OSError:
        return False


# ---------- prompts ----------
def ask(msg, default=None, cast=str, ok=lambda v: True):
    while True:
        raw = input(f"{msg}{f' [{default}]' if default is not None else ''}: ").strip()
        if not raw:
            if default is not None:
                return default
            print("  (required)")
            continue
        try:
            val = cast(raw)
        except ValueError:
            print(f"  not a valid {cast.__name__}")
            continue
        if not ok(val):
            print("  invalid value")
            continue
        return val


def ask_yes(msg, default=True):
    raw = input(f"{msg} [{'Y/n' if default else 'y/N'}]: ").strip().lower()
    return default if not raw else raw.startswith("y")


# ---------- environment ----------
def preflight():
    """Fail early, with a clear message, if the environment isn't ready."""
    missing = []
    if not shutil.which("nextflow"):
        missing.append("nextflow  (https://www.nextflow.io/ -- needs Java 11+)")
    if not shutil.which("java"):
        missing.append("java 11+  (e.g. sudo apt install default-jre)")
    if not shutil.which("docker"):
        missing.append("docker    (the Docker engine)")
    if missing:
        sys.exit("Missing required tools:\n  - " + "\n  - ".join(missing))

    r = subprocess.run(["docker", "info"], stdout=subprocess.DEVNULL,
                       stderr=subprocess.PIPE, text=True)
    if r.returncode != 0:
        if "permission denied" in (r.stderr or "").lower():
            sys.exit(
                "Docker is installed but you don't have permission to use it.\n"
                "Add yourself to the docker group, then restart WSL:\n"
                "  sudo usermod -aG docker $USER\n"
                "  (then run `wsl --shutdown` from Windows and reopen Ubuntu)"
            )
        sys.exit(
            "Docker is installed but the daemon isn't reachable.\n"
            "Start it (Docker Desktop, or `sudo service docker start`) and try again."
        )


def run_step(cmd, cwd):
    if subprocess.run(cmd, env=dict(os.environ), cwd=str(cwd)).returncode != 0:
        sys.exit("\nA pipeline step failed -- see the Nextflow output above.")


# ---------- cache / store helpers ----------
# The output location (--out) holds ONLY data/. All transient bits -- the Nextflow work
# dir, the run-staging symlink, the finish placeholder, and the small per-location memory
# (boxes-per-shelf / stabilize / last-used) -- live under ~/.cache/image-sort instead.
def cache_subdir(*parts):
    d = CACHE.joinpath(*parts)
    d.mkdir(parents=True, exist_ok=True)
    return d


def work_dir_for(store):
    """Nextflow work dir for a location, kept OUT of it (transient, resumable)."""
    tag = hashlib.sha1(str(store).encode()).hexdigest()[:12]
    return cache_subdir("work", tag)


def _read_all_meta():
    f = CACHE / "stores.json"
    if f.is_file():
        try:
            return json.loads(f.read_text())
        except Exception:
            return {}
    return {}


def _write_all_meta(data):
    try:
        CACHE.mkdir(parents=True, exist_ok=True)
        (CACHE / "stores.json").write_text(json.dumps(data, indent=2))
    except OSError:
        pass


def load_meta(store):
    return _read_all_meta().get("stores", {}).get(str(store), {})


def save_meta(store, meta):
    data = _read_all_meta()
    data.setdefault("stores", {})[str(store)] = meta
    data["last"] = str(store)
    _write_all_meta(data)


def last_store():
    return _read_all_meta().get("last")


def resolve_store(a, interactive):
    """The persistent output location (== --sort_path). Same path every time -> accumulates."""
    raw = a.out
    if not raw:
        if not interactive:
            sys.exit("No output location given. Pass --out <path> -- the persistent location "
                     "that holds data/master_data + data/videos.")
        prompt = "Output location (holds data/master_data + data/videos)"
        default = last_store()
        raw = ask(prompt, default=default) if default else ask(prompt)
    store = to_path(raw, "Output location").resolve()
    data = _read_all_meta()
    data["last"] = str(store)
    _write_all_meta(data)
    return store


def stabilized_videos(sort_path):
    d = sort_path / "data" / "videos" / "stabilized"
    return {p.name for p in d.glob("*.mp4")} if d.is_dir() else set()


def derive_geometry(folder_name):
    """(shelves, boxes) from a run-folder name '<timestamp>_<shelves>_<boxes>'.

    The robot encodes both: number after the final underscore is boxes-per-shelf, the one
    before it is the shelf count. Returns ints, or (None, None) if the name doesn't carry
    both (older '<timestamp>_<shelves>' folders, or ad-hoc names -- use --shelves /
    --boxes-per-shelf then).
    """
    parts = folder_name.rsplit("_", 2)
    if len(parts) == 3 and parts[1].isdigit() and parts[2].isdigit():
        return int(parts[1]), int(parts[2])
    return None, None


def nf_base(sort_path, work_dir, revision, archive=False):
    return ["nextflow", "run", PIPELINE, "-r", revision, "-latest", "-profile", "local",
            "-work-dir", str(work_dir),
            "--sort_path", str(sort_path),
            "--unzip", "false", "--archive", "true" if archive else "false"]


def resolve_dest(a, wsl, interactive):
    if a.dest is not None:
        raw = a.dest
    elif interactive:
        hint = "Windows path, or " if wsl else ""
        raw = input(f"Copy new videos to ({hint}Enter to keep in WSL only): ").strip()
    else:
        raw = ""
    return to_path(raw, "Destination").resolve() if raw else None


def finish_report(sort_path, before, dest, wsl):
    """Copy newly-rendered stabilized videos to dest (if any) and print where things landed."""
    new = sorted(stabilized_videos(sort_path) - before)
    stab = sort_path / "data" / "videos" / "stabilized"
    if dest and new:
        print(f"-> Copying {len(new)} new video(s) to {win_display(dest) or dest} ...")
        try:
            dest.mkdir(parents=True, exist_ok=True)
            for v in new:
                shutil.copy2(stab / v, dest / v)
        except (PermissionError, OSError) as e:
            print(f"  WARNING: could not copy videos to {dest}: {e}")

    print("\nDone.")
    print(f"  Location: {win_display(sort_path) or sort_path}")
    if new:
        print(f"  Finished this run: {', '.join(v[:-4] for v in new)}")
        print(f"  Videos:  {stab}")
    else:
        print("  No experiments finished this run.")
    if wsl:
        print(f"  Open in Explorer: {wsl_unc(sort_path)}")
    if dest:
        print(f"  Copied new videos to: {win_display(dest) or dest}")


# ---------- modes ----------
def do_sort(a, wsl, interactive):
    img_prompt = "Images folder" + (" (paste the Windows C:\\ path)" if wsl else "")
    images = to_path(a.images if a.images else ask(img_prompt), "Images folder")
    if not images.is_dir():
        hint = ("\n(if this is on a network or external drive, it may not be mounted in WSL)"
                if str(images).startswith("/mnt/") else "")
        sys.exit(f"Images folder not found: {images}{hint}")
    source_name = images.name

    store = resolve_store(a, interactive)
    work_dir = work_dir_for(store)

    if a.overwrite and store.exists():
        if not interactive or ask_yes(
                f"Delete and recreate the ENTIRE location at {win_display(store) or store} "
                "(wipes all experiments)?", default=False):
            shutil.rmtree(store)

    # Imaging geometry: the robot encodes it in the folder name as
    # <timestamp>_<shelves>_<boxes> (boxes = the final segment, shelves the one before it).
    # --shelves / --boxes-per-shelf override; remembered boxes (per location) is a fallback.
    name_shelves, name_boxes = derive_geometry(source_name)
    meta = load_meta(store)

    shelves = a.shelves if a.shelves else name_shelves
    if shelves is None:
        sys.exit(f"Couldn't read the shelf count from folder name '{source_name}'.\n"
                 "The robot names runs <timestamp>_<shelves>_<boxes> (e.g. 20260613120000_3_8).\n"
                 "Pass --shelves N (and --boxes-per-shelf N), or rename the folder.")
    shelves = int(shelves)
    if not (1 <= shelves <= 99):
        sys.exit(f"Implausible shelf count ({shelves}) read from '{source_name}'.\n"
                 "If the folder name's trailing _<shelves>_<boxes> is wrong, pass --shelves N.")

    boxes = a.boxes_per_shelf or name_boxes or meta.get("boxes_per_shelf")
    if not boxes:
        boxes = ask("Boxes per shelf", default=2, cast=int, ok=lambda v: v > 0)
    boxes = int(boxes)

    shelf_src = ("--shelves override" if a.shelves
                 else f"from folder name {source_name!r}" if name_shelves else "fallback")
    box_src = ("--boxes-per-shelf override" if a.boxes_per_shelf
               else "from folder name" if name_boxes else "remembered/asked")
    print(f"-> Using {shelves} shelf(s) ({shelf_src}) x {boxes} box(es)/shelf ({box_src}).")
    if a.stabilize is not None:
        stabilize = a.stabilize
    else:
        stabilize = meta.get("stabilize", True)

    store.mkdir(parents=True, exist_ok=True)
    save_meta(store, {"boxes_per_shelf": boxes, "stabilize": stabilize})

    # The pipeline reads geometry from the staged folder name, so it must end in
    # '_<shelves>_<boxes>'. Robot folders already do; otherwise append it (needed for
    # --shelves/--boxes-per-shelf overrides / non-conventional names). Staging lives in the
    # cache -- NOT the location -- so the location only ever holds data/.
    geo_suffix = f"_{shelves}_{boxes}"
    staged_name = source_name if source_name.endswith(geo_suffix) else source_name + geo_suffix
    staged = cache_subdir("staging") / staged_name
    if staged.is_symlink() or staged.exists():
        staged.unlink()
    staged.symlink_to(images, target_is_directory=True)

    # Defensive: clear transient ingest residue left by an interrupted prior run with this name
    # (the pipeline's copytree into unsorted_unlabeled/<name> errors if it already exists).
    for sub in ("unsorted_unlabeled", "sorted_unlabeled"):
        leftover = store / "data" / "master_data" / sub / staged_name
        if leftover.exists():
            shutil.rmtree(leftover, ignore_errors=True)

    if a.archive:
        # Archiving moves the raw run out of the source folder into the location's
        # data/unsorted_unlabeled_processed/ AFTER images are copied in for sorting. The
        # source folder ends up empty -- safe (the images live in the location now), but the
        # original location is consumed. Confirm interactively since it's not reversible there.
        src_disp = win_display(images) or images
        print(f"NOTE: --archive will MOVE (empty) the source folder after sorting:\n  {src_disp}")
        if interactive and not ask_yes("Proceed and archive (empty) the source folder?", default=True):
            sys.exit("Cancelled.")

    before = stabilized_videos(store)
    cmd = nf_base(store, work_dir, a.revision, archive=a.archive) + [
        "--images_path", str(staged),
        "--boxes_per_shelf", str(boxes),
        "--stabilize", "true" if stabilize else "false",
    ]
    print(f"\n-> Sorting {source_name} into {win_display(store) or store}  "
          f"({boxes} boxes x {shelves} shelves"
          f"{'; archiving source after' if a.archive else ''})...")
    run_step(cmd, cache_subdir("run"))

    dest = resolve_dest(a, wsl, interactive)
    finish_report(store, before, dest, wsl)


def do_finish(a, wsl, interactive, mode):
    store = resolve_store(a, interactive)
    work_dir = work_dir_for(store)
    if not (store / "data" / "master_data").is_dir():
        sys.exit(f"No store found at {win_display(store) or store}. Sort a run into it first.")

    meta = load_meta(store)
    boxes = a.boxes_per_shelf or meta.get("boxes_per_shelf") or 1  # placeholder; not used to sort
    stabilize = a.stabilize if a.stabilize is not None else meta.get("stabilize", True)

    # The finish branch ignores images, but the pipeline still stages an images path -> give it
    # a harmless empty placeholder (in the cache, not the location).
    placeholder = cache_subdir("staging", "_finish_placeholder")

    cmd = nf_base(store, work_dir, a.revision) + [
        "--images_path", str(placeholder),
        "--boxes_per_shelf", str(boxes),
        "--stabilize", "true" if stabilize else "false",
    ]

    where = win_display(store) or store
    if mode == "finish":
        raw = a.exp or ask("Experiment number(s) to finish (comma-separated)")
        exps = ",".join(e.strip() for e in raw.split(",") if e.strip())
        if not exps:
            sys.exit("No experiment numbers given.")
        cmd += ["--finish_experiments", exps]
        print(f"\n-> Finishing experiment(s) {exps} in {where}...")
    else:  # finish-all
        if interactive and not ask_yes(
                f"Finish ALL experiments in {where} and turn it over?", default=False):
            sys.exit("Cancelled.")
        cmd += ["--finish_only", "true"]
        print(f"\n-> Finishing ALL experiments in {where} (turning it over)...")

    before = stabilized_videos(store)
    run_step(cmd, cache_subdir("run"))
    dest = resolve_dest(a, wsl, interactive)
    finish_report(store, before, dest, wsl)


def main():
    ap = argparse.ArgumentParser(description="Sort robot images and build root-growth videos.")
    ap.add_argument("--mode", choices=["sort", "finish", "finish-all"],
                    help="What to do (default: inferred -- sort if --images, finish if --exp).")
    ap.add_argument("--out", help="Persistent output location holding data/master_data + "
                                  "data/videos. Pass the SAME path every time so runs accumulate.")
    ap.add_argument("--images", help="[sort] Images folder for this run (Windows or WSL path).")
    ap.add_argument("--exp", help="[finish] Experiment number(s) to finalize, comma-separated.")
    ap.add_argument("--boxes-per-shelf", type=int,
                    help="[sort] Override boxes per shelf (normally read from the folder name; "
                         "remembered per location as a fallback).")
    ap.add_argument("--shelves", type=int,
                    help="[sort] Override shelf count (normally read from the folder name).")
    ap.add_argument("--dest", help="Copy newly-finished videos here (Windows or Linux path). Optional.")
    ap.add_argument("--stabilize", dest="stabilize", action="store_true", default=None,
                    help="Stabilize videos (default).")
    ap.add_argument("--no-stabilize", dest="stabilize", action="store_false",
                    help="Skip stabilization.")
    ap.add_argument("--archive", action="store_true",
                    help="[sort] After sorting, MOVE the raw run out of the source folder into "
                         "the location's data/unsorted_unlabeled_processed/ (empties the source).")
    ap.add_argument("--overwrite", action="store_true",
                    help="[sort] Delete and recreate the ENTIRE output location before sorting.")
    ap.add_argument("--revision", default=REVISION, help="Pipeline git revision to run (advanced).")
    a = ap.parse_args()

    preflight()
    wsl = on_wsl()
    interactive = sys.stdin.isatty()

    mode = a.mode
    if mode is None:
        if a.exp is not None:
            mode = "finish"
        elif a.images is not None:
            mode = "sort"
        elif interactive:
            print("What would you like to do?")
            print("  1) Sort a new run into your output location")
            print("  2) Finish specific experiments (make videos)")
            print("  3) Finish all experiments (turn over the location)")
            mode = {"1": "sort", "2": "finish", "3": "finish-all"}[
                ask("Choose", default="1", ok=lambda v: v in ("1", "2", "3"))]
        else:
            sys.exit("Nothing to do. Pass --mode sort|finish|finish-all (or --images / --exp).")

    if mode == "sort":
        do_sort(a, wsl, interactive)
    else:
        do_finish(a, wsl, interactive, mode)


if __name__ == "__main__":
    main()
